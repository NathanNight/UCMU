rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return firestore.get(/databases/(default)/documents/users/$(uid));
    }

    function isActiveUser() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.disabled != true;
    }

    function isChatMember(chatId) {
      return isActiveUser()
        && firestore.exists(/databases/(default)/documents/chats/$(chatId))
        && request.auth.uid in firestore.get(/databases/(default)/documents/chats/$(chatId)).data.members;
    }

    match /chatFiles/{chatId}/{messageId}/{fileName} {
      allow read: if isChatMember(chatId);
      allow write: if isChatMember(chatId)
        && request.resource.size < 25 * 1024 * 1024;
    }

    match /avatars/{uid}/{fileName} {
      allow read: if isActiveUser();
      allow write: if signedIn()
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
