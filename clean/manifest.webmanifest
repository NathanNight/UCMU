{
  "name": "U.C.M.U Chat",
  "short_name": "U.C.M.U",
  "description": "U.C.M.U secure communications chat",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "fullscreen", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#020303",
