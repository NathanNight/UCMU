{
  "name": "ucmu-chat",
  "version": "0.1.0",
  "private": true,
  "description": "U.C.M.U Chat clean mobile shell",
  "scripts": {
    "cap:init": "npx cap init UCMU io.ucmu.chat --web-dir=clean",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "mobile:android": "npx cap sync android && npx cap open android",
    "mobile:ios": "npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "latest",
    "@capacitor/app": "latest",
    "@capacitor/core": "latest",
    "@capacitor/ios": "latest",
    "@capacitor/keyboard": "latest",
    "@capacitor/status-bar": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "latest"
  }
}
