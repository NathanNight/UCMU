rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isActiveUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.disabled != true;
    }

    function isChatMember(chatId) {
      return isActiveUser()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    function isAuthor() {
      return request.resource.data.authorId == request.auth.uid;
    }

    match /invites/{inviteCode} {
      // Клиент может проверить только сам код, который ввёл.
      allow get: if true;
      allow list: if false;

      // После регистрации клиент помечает инвайт использованным только своим uid.
      allow update: if signedIn()
        && resource.data.disabled != true
        && !('usedBy' in resource.data)
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['usedBy', 'usedAt']);

      allow create, delete: if false;
    }

    match /users/{uid} {
      allow get: if isActiveUser() || isSelf(uid);
      allow list: if false;

      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'member'
        && request.resource.data.disabled == false;

      allow update: if isSelf(uid)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.disabled == resource.data.disabled;

      allow delete: if false;

      match /folders/{folderId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /chats/{chatId} {
      allow get, list: if isChatMember(chatId);

      // Создание чата с собой в members. Для групп позже можно ужесточить через creatorId.
      allow create: if isActiveUser()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 20;

      allow update: if isChatMember(chatId)
        && request.resource.data.members == resource.data.members;

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);

        allow create: if isChatMember(chatId)
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly([
            'authorId','authorName','type','text','file','size','createdAt','updatedAt','deletedFor','deletedForAll','reactions','replyTo'
          ]);

        allow update: if isChatMember(chatId)
          && (
            // Автор может редактировать/удалять своё сообщение.
            (resource.data.authorId == request.auth.uid)
            ||
            // Любой участник может менять только reactions/deletedFor.
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['reactions','deletedFor','updatedAt'])
          );

        allow delete: if false;
      }
    }
  }
}
