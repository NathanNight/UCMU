rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isActiveUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.disabled != true;
    }

    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    function isChatMember(chatId) {
      return isActiveUser()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in chatDoc(chatId).data.members;
    }

    function joinsGeneralOnly(chatId) {
      return isActiveUser()
        && chatId == 'general'
        && request.auth.uid in request.resource.data.members
        && !(request.auth.uid in resource.data.members)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['members', 'updatedAt'])
        && request.resource.data.members.size() == resource.data.members.size() + 1;
    }

    match /invites/{inviteCode} {
      allow get: if true;
      allow list: if false;

      allow update: if signedIn()
        && resource.data.disabled != true
        && !('usedBy' in resource.data)
        && request.resource.data.usedBy == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['usedBy', 'usedAt']);

      allow create, delete: if false;
    }

    match /users/{uid} {
      allow get: if isActiveUser() || isSelf(uid);
      allow list: if false;

      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == 'member'
        && request.resource.data.disabled == false;

      allow update: if isSelf(uid)
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
        && request.resource.data.disabled == resource.data.disabled;

      allow delete: if false;

      match /folders/{folderId} {
        allow read, write: if isSelf(uid);
      }
    }

    match /chats/{chatId} {
      allow get: if isChatMember(chatId);

      // Нужно для запроса списка чатов: where('members','array-contains', uid).
      // Чтение сообщений всё равно закрыто отдельно через isChatMember(chatId).
      allow list: if isActiveUser();

      allow create: if isActiveUser()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members is list
        && request.resource.data.members.size() <= 20;

      allow update: if
        (
          isChatMember(chatId)
          && request.resource.data.members == resource.data.members
        )
        || joinsGeneralOnly(chatId);

      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);

        allow create: if isChatMember(chatId)
          && request.resource.data.authorId == request.auth.uid
          && request.resource.data.createdAt == request.time
          && request.resource.data.keys().hasOnly([
            'authorId','authorName','type','text','file','size',
            'createdAt','updatedAt','deletedFor','deletedForAll',
            'reactions','replyTo'
          ]);

        allow update: if isChatMember(chatId)
          && (
            resource.data.authorId == request.auth.uid
            ||
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'reactions','deletedFor','updatedAt'
            ])
          );

        allow delete: if false;
      }
    }
  }
}
